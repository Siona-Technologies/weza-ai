# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000

# Local testing without API keys: set to true to use stubbed AI extraction
# (keyword heuristics for text, canned results for photo/voice). No API cost.
MOCK_AI=false

# Twilio WhatsApp (from Twilio Console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox number for local dev, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Phase 2: AI extraction ---
# Which vendor does receipt vision + categorization: anthropic (default) | openai.
# Voice is always Whisper (OpenAI) regardless. Set this to score both vendors on
# the same receipts before committing to one.
# AI_PROVIDER=anthropic

# Claude API (receipt vision + categorization when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Optional overrides
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_EFFORT=medium

# OpenAI. Always needed for voice (Whisper); also does vision + categorization
# when AI_PROVIDER=openai. One key covers every OpenAI model.
OPENAI_API_KEY=
# WHISPER_MODEL=whisper-1
# Vision/categorization model. terra balances accuracy and latency; sol is
# stronger but slower; luna is cheapest.
# OPENAI_MODEL=gpt-5.6-terra

# --- Phase 3: database ---
# PostgreSQL connection string (Render managed Postgres, or local for dev).
# Render: use the "Internal Database URL" from the database dashboard.
DATABASE_URL=

# --- Added in later phases ---
# Cloudinary (image storage)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
