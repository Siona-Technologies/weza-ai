# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000

# Local testing without API keys: set to true to use stubbed AI extraction
# (keyword heuristics for text, canned results for photo/voice). No API cost.
MOCK_AI=false

# Twilio WhatsApp (from Twilio Console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox number for local dev, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Phase 2: AI extraction ---
# Which vendor does receipt vision + categorization: anthropic (default) | openai.
# Voice is always Whisper (OpenAI) regardless. Set this to score both vendors on
# the same receipts before committing to one.
# AI_PROVIDER=anthropic

# Per-attempt timeout for any AI call. The SDK default is 10 minutes, which for
# us means a hung request leaves the owner with no reply and no error. Real
# extractions take 4-23s.
# AI_TIMEOUT_MS=45000

# Retries on 429/5xx/timeouts. The SDKs handle the backoff; this just sets how
# many. Worst case before the owner is told we failed is roughly
# AI_TIMEOUT_MS x (AI_MAX_RETRIES + 1) plus backoff.
# AI_MAX_RETRIES=2

# Claude API (receipt vision + categorization when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Optional overrides
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_EFFORT=medium

# OpenAI. Always needed for voice (Whisper); also does vision + categorization
# when AI_PROVIDER=openai. One key covers every OpenAI model.
OPENAI_API_KEY=
# WHISPER_MODEL=whisper-1
# Vision/categorization model. terra balances accuracy and latency; sol is
# stronger but slower; luna is cheapest.
# OPENAI_MODEL=gpt-5.6-terra

# --- Phase 3: database ---
# PostgreSQL connection string (Render managed Postgres, or local for dev).
# Render: use the "Internal Database URL" from the database dashboard.
DATABASE_URL=

# --- Cost reporting (npm run cost) ---
# Usage (tokens, audio seconds, messages) is always measured. These turn that
# usage into money. Deliberately NOT given default values: prices change, vary
# by region and vary by account, and a plausible-looking guess would produce a
# confidently wrong report that pricing decisions then get made on.
#
# Fill these in from YOUR invoices — the OpenAI and Anthropic billing pages, and
# Twilio's WhatsApp pricing for Kenya. Anything left unset is reported as
# UNKNOWN, and the report says so rather than under-counting silently.
#
# USD per 1,000,000 tokens:
# COST_OPENAI_INPUT_PER_MTOK=
# COST_OPENAI_OUTPUT_PER_MTOK=
# COST_ANTHROPIC_INPUT_PER_MTOK=
# COST_ANTHROPIC_OUTPUT_PER_MTOK=
# USD per minute of transcribed audio:
# COST_WHISPER_PER_MINUTE=
# USD per outbound WhatsApp message (Twilio's rate, which includes Meta's fee):
# COST_WHATSAPP_PER_MESSAGE=
# Optional: also show costs in shillings.
# USD_TO_KES=

# --- Receipt image storage (Cloudinary) ---
# Without these the pipeline still works — receipts are read and then discarded,
# which is what happened before this existed. With them, the photo is kept so a
# disputed entry has the evidence behind it.
#
# From the Cloudinary dashboard. Images are uploaded as `authenticated`, so they
# are NOT on a public URL: viewing one needs a signed link we generate on demand.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Where receipts live. Each business gets a subfolder, so everything belonging to
# one owner can be found — and deleted — in one place.
# CLOUDINARY_FOLDER=weza-ai/receipts
